{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "layout": {
      "contentSize": "844px",
      "wideSize": "1024px"
    },
    "useRootPaddingAwareAlignments": true,
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true,
      "spacingSizes": [
        {
          "size": "calc(var(--wp--preset--font-size--x-small) * 0.75)",
          "slug": "20",
          "name": "1"
        },
        {
          "size": "calc(var(--wp--preset--font-size--x-small) * 1.5)",
          "slug": "30",
          "name": "2"
        },
        {
          "size": "calc(var(--wp--preset--font-size--small) * 1.5)",
          "slug": "40",
          "name": "3"
        },
        {
          "size": "calc(var(--wp--preset--font-size--medium) * 1.5)",
          "slug": "50",
          "name": "4"
        },
        {
          "size": "calc(var(--wp--preset--font-size--large) * 1.5)",
          "slug": "60",
          "name": "5"
        },
        {
          "size": "calc(var(--wp--preset--font-size--x-large) * 1.5)",
          "slug": "70",
          "name": "6"
        },
        {
          "size": "calc(var(--wp--preset--font-size--x-large) * 2.33)",
          "slug": "80",
          "name": "7"
        }
      ]
    },
    "color": {
      "link": false,
      "defaultPalette": false,
      "palette": [
        { "name": "Black", "slug": "black", "color": "#000" },
        { "name": "Dark Gray", "slug": "gray-dark", "color": "#5E6463" },
        { "name": "Gray", "slug": "gray", "color": "#858b8a" },
        { "name": "Light Gray", "slug": "gray-light", "color": "#cbd1d0" },
        { "name": "Lighter Gray", "slug": "gray-lighter", "color": "#e9efee" },
        { "name": "White", "slug": "white", "color": "#fff" },

        { "name": "Charcoal", "slug": "charcoal", "color": "#0d1312" },
        { "name": "Darker Clay", "slug": "clay-darker", "color": "#b4b195" },
        { "name": "Dark Clay", "slug": "clay-dark", "color": "#d7d4b2" },
        { "name": "Clay", "slug": "clay", "color": "#f0efe5" },
        { "name": "Light Clay", "slug": "clay-light", "color": "#f7f7f2" },

        { "name": "Purple", "slug": "purple", "color": "#9766E3" },

        { "name": "Dark Mint", "slug": "mint-dark", "color": "#3FB197" },
        { "name": "Mint", "slug": "mint", "color": "#50e3c2" },
        { "name": "Light Mint", "slug": "mint-light", "color": "#D9F9F1" },

        { "name": "Red (Danger)", "slug": "red-danger", "color": "#b00020" }
      ],
      "custom": true,
      "customGradient": true,
      "defaultGradients": false,
      "defaultDuotone": false,
      "customDuotone": false
    },
    "typography": {
      "fluid": true,
      "fontSizes": [
        {
          "slug": "x-small",
          "size": "14px",
          "name": "Extra Small",
          "fluid": {
            "min": "12px",
            "max": "14px"
          }
        },
        {
          "slug": "small",
          "size": "16px",
          "name": "Small",
          "fluid": {
            "min": "14px",
            "max": "16px"
          }
        },
        {
          "slug": "medium",
          "size": "20px",
          "name": "Medium",
          "fluid": {
            "min": "16px",
            "max": "20px"
          }
        },
        {
          "slug": "medium-large",
          "size": "24px",
          "name": "Medium Large",
          "fluid": {
            "min": "20px",
            "max": "24px"
          }
        },
        {
          "slug": "large",
          "size": "32px",
          "name": "Large",
          "fluid": {
            "min": "24px",
            "max": "32px"
          }
        },
        {
          "slug": "x-large",
          "size": "48px",
          "name": "Extra Large",
          "fluid": {
            "min": "32px",
            "max": "48px"
          }
        },
        {
          "name": "2X Large",
          "slug": "xx-large",
          "size": "56px",
          "fluid": {
            "min": "36px",
            "max": "56px"
          }
        }
      ],
      "fontFamilies": [
        {
          "fontFamily": "Menlo, Consolas, monospace",
          "name": "Monospace Stack",
          "slug": "monospace"
        },
        {
          "fontFamily": "var(--font-family__ttnorms)",
          "name": "TT Norms",
          "slug": "ttnorms"
        },
        {
          "fontFamily": "var(--font-family__grifo)",
          "name": "Grifo",
          "slug": "grifo"
        },
        {
          "fontFamily": "Avenir, sans-serif",
          "name": "Sans-Serif (Avenir)",
          "slug": "sans"
        },
        {
          "fontFamily": "-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Oxygen-Sans,Ubuntu,Cantarell,Helvetica Neue,sans-serif",
          "slug": "system-fonts",
          "name": "System Fonts"
        }
      ],
      "dropCap": false
    },

    "blocks": {
      "core/button": {
        "typography": {
          "fontSizes": [],
          "customFontSize": false
        },
        "border": {
          "radius": false
        }
      }
    }
  },

  "styles": {
    "color": {
      "text": "var:preset|color|charcoal"
    },

    "spacing": {
      "padding": { "top": "0", "right": "48px", "bottom": "0", "left": "48px" },
      "blockGap": "var:preset|spacing|30"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|sans",
      "lineHeight": "1.5",
      "fontWeight": "500",
      "fontSize": "var:preset|font-size|medium"
    },

    "blocks": {
      "core/button": {
        "typography": {
          "fontSize": "16px",
          "fontWeight": "500",
          "textDecoration": "none !important"
        },
        "css": "&:after {content: '➝'; display: inline-block; font-size: 24px; line-height: 16px; vertical-align: -4px; margin: 0 -10px 0 10px; }",
        "variations": {
          "outline": {
            "border": { "width": "1px" },
            "spacing": {
              "padding": {
                "top": "16px",
                "right": "31px",
                "bottom": "14px",
                "left": "31px"
              }
            }
          }
        },
        "color": {
          "background": "var:preset|color|mint",
          "text": "var:preset|color|charcoal"
        },
        "border": { "radius": "0" },
        "spacing": {
          "padding": {
            "top": "17px",
            "right": "32px",
            "bottom": "15px",
            "left": "32px"
          }
        }
      },
      "core/buttons": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|50"
          }
        }
      },
      "core/columns": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|60",
            "bottom": "var:preset|spacing|20"
          },
          "blockGap": "var:preset|spacing|70"
        }
      },
      "core/cover": {
        "dimensions": { "minHeight": "0" },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|70",
            "bottom": "var:preset|spacing|70"
          },
          "padding": {
            "top": "var:preset|spacing|70",
            "bottom": "var:preset|spacing|70"
          }
        }
      },
      "core/list": {
        "typography": {
          "fontSize": "var:preset|font-size|medium"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|50"
          }
        }
      },
      "core/more": {
        "css": "& input{ text-transform: none; }"
      },
      "core/paragraph": {
        "typography": {
          "fontSize": "var:preset|font-size|medium"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|30",
            "bottom": "var:preset|spacing|20"
          }
        },
        "css": " &:is(p.is-style-caption) { font-size: var(--wp--preset--font-size--x-small); line-height: 1.25; color: var(--wp--preset--color--gray); } &:is(p.is-style-caption):last-of-type { border-top: 1px solid var(--wp--preset--color--mint-dark); margin-top: var(--wp--preset--font-size--xx-large); padding-top: var(--wp--preset--font-size--medium-large); } &:is(p.is-style-caption.block-editor-block-list__block) { border-top-width: 2px; }"
      },
      "core/post-title": {
        "css": "&:is(h1.editor-post-title) { font-size: var(--wp--preset--font-size--xx-large); font-weight: 600; }"
      },
      "core/quote": {
        "css": "& cite > strong { font-weight: 700}",
        "elements": {
          "cite": {
            "typography": {
              "fontSize": "var:preset|font-size|small",
              "fontWeight": "400"
            }
          }
        }
      },
      "core/separator": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|50"
          },
          "padding": { "top": "2px" }
        },
        "border": {
          "width": "0"
        },
        "color": {
          "background": "var:preset|color|charcoal"
        }
      }
    },
    "elements": {
      "caption": {
        "typography": {
          "fontSize": "var:preset|font-size|x-small",
          "fontWeight": "400",
          "fontStyle": "normal",
          "lineHeight": "1.25"
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var(--font-family__ttnorms)",
          "lineHeight": "1.15"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|50"
          }
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large",
          "fontStyle": "normal",
          "fontWeight": "400"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var:preset|font-size|xx-large"
          }
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var:preset|font-size|x-large",
          "fontStyle": "normal",
          "fontWeight": "350"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|80",
            "bottom": "var:preset|spacing|50"
          }
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var:preset|font-size|large",
          "fontWeight": "800"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|20"
          }
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var:preset|font-size|medium",
          "fontWeight": "700",
          "textTransform": "uppercase"
        }
      }
    }
  }
}
