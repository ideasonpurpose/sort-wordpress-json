{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "custom": true,
      "customDuotone": false,
      "customGradient": true,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "link": false,
      "palette": [
        {
          "name": "Black",
          "slug": "black",
          "color": "#000"
        },
        {
          "name": "Dark Gray",
          "slug": "gray-dark",
          "color": "#5E6463"
        },
        {
          "name": "Gray",
          "slug": "gray",
          "color": "#858b8a"
        },
        {
          "name": "Light Gray",
          "slug": "gray-light",
          "color": "#cbd1d0"
        },
        {
          "name": "Lighter Gray",
          "slug": "gray-lighter",
          "color": "#e9efee"
        },
        {
          "name": "White",
          "slug": "white",
          "color": "#fff"
        },
        {
          "name": "Charcoal",
          "slug": "charcoal",
          "color": "#0d1312"
        },
        {
          "name": "Darker Clay",
          "slug": "clay-darker",
          "color": "#b4b195"
        },
        {
          "name": "Dark Clay",
          "slug": "clay-dark",
          "color": "#d7d4b2"
        },
        {
          "name": "Clay",
          "slug": "clay",
          "color": "#f0efe5"
        },
        {
          "name": "Light Clay",
          "slug": "clay-light",
          "color": "#f7f7f2"
        },
        {
          "name": "Purple",
          "slug": "purple",
          "color": "#9766E3"
        },
        {
          "name": "Dark Mint",
          "slug": "mint-dark",
          "color": "#3FB197"
        },
        {
          "name": "Mint",
          "slug": "mint",
          "color": "#50e3c2"
        },
        {
          "name": "Light Mint",
          "slug": "mint-light",
          "color": "#D9F9F1"
        },
        {
          "name": "Red (Danger)",
          "slug": "red-danger",
          "color": "#b00020"
        }
      ]
    },
    "layout": {
      "contentSize": "844px",
      "wideSize": "1024px"
    },
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true,
      "spacingSizes": [
        {
          "name": "1",
          "slug": "20",
          "size": "calc(var(--wp--preset--font-size--x-small) * 0.75)"
        },
        {
          "name": "2",
          "slug": "30",
          "size": "calc(var(--wp--preset--font-size--x-small) * 1.5)"
        },
        {
          "name": "3",
          "slug": "40",
          "size": "calc(var(--wp--preset--font-size--small) * 1.5)"
        },
        {
          "name": "4",
          "slug": "50",
          "size": "calc(var(--wp--preset--font-size--medium) * 1.5)"
        },
        {
          "name": "5",
          "slug": "60",
          "size": "calc(var(--wp--preset--font-size--large) * 1.5)"
        },
        {
          "name": "6",
          "slug": "70",
          "size": "calc(var(--wp--preset--font-size--x-large) * 1.5)"
        },
        {
          "name": "7",
          "slug": "80",
          "size": "calc(var(--wp--preset--font-size--x-large) * 2.33)"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "dropCap": false,
      "fontSizes": [
        {
          "name": "Extra Small",
          "slug": "x-small",
          "size": "14px",
          "fluid": {
            "max": "14px",
            "min": "12px"
          }
        },
        {
          "name": "Small",
          "slug": "small",
          "size": "16px",
          "fluid": {
            "max": "16px",
            "min": "14px"
          }
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "20px",
          "fluid": {
            "max": "20px",
            "min": "16px"
          }
        },
        {
          "name": "Medium Large",
          "slug": "medium-large",
          "size": "24px",
          "fluid": {
            "max": "24px",
            "min": "20px"
          }
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "32px",
          "fluid": {
            "max": "32px",
            "min": "24px"
          }
        },
        {
          "name": "Extra Large",
          "slug": "x-large",
          "size": "48px",
          "fluid": {
            "max": "48px",
            "min": "32px"
          }
        },
        {
          "name": "2X Large",
          "slug": "xx-large",
          "size": "56px",
          "fluid": {
            "max": "56px",
            "min": "36px"
          }
        }
      ],
      "fontFamilies": [
        {
          "name": "Monospace Stack",
          "slug": "monospace",
          "fontFamily": "Menlo, Consolas, monospace"
        },
        {
          "name": "TT Norms",
          "slug": "ttnorms",
          "fontFamily": "var(--font-family__ttnorms)"
        },
        {
          "name": "Grifo",
          "slug": "grifo",
          "fontFamily": "var(--font-family__grifo)"
        },
        {
          "name": "Sans-Serif (Avenir)",
          "slug": "sans",
          "fontFamily": "Avenir, sans-serif"
        },
        {
          "name": "System Fonts",
          "slug": "system-fonts",
          "fontFamily": "-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Oxygen-Sans,Ubuntu,Cantarell,Helvetica Neue,sans-serif"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true,
    "blocks": {
      "core/button": {
        "border": {
          "radius": false
        },
        "typography": {
          "customFontSize": false,
          "fontSizes": []
        }
      }
    }
  },
  "styles": {
    "color": {
      "text": "var:preset|color|charcoal"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|30",
      "padding": {
        "top": "0",
        "right": "48px",
        "bottom": "0",
        "left": "48px"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|sans",
      "fontSize": "var:preset|font-size|medium",
      "fontWeight": "500",
      "lineHeight": "1.5"
    },
    "elements": {
      "heading": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|50"
          }
        },
        "typography": {
          "fontFamily": "var(--font-family__ttnorms)",
          "lineHeight": "1.15"
        }
      },
      "h1": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var:preset|font-size|xx-large"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|xx-large",
          "fontStyle": "normal",
          "fontWeight": "400"
        }
      },
      "h2": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|80",
            "bottom": "var:preset|spacing|50"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|x-large",
          "fontStyle": "normal",
          "fontWeight": "350"
        }
      },
      "h3": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|20"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|large",
          "fontWeight": "800"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var:preset|font-size|medium",
          "fontWeight": "700",
          "textTransform": "uppercase"
        }
      },
      "caption": {
        "typography": {
          "fontSize": "var:preset|font-size|x-small",
          "fontStyle": "normal",
          "fontWeight": "400",
          "lineHeight": "1.25"
        }
      }
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "0"
        },
        "color": {
          "background": "var:preset|color|mint",
          "text": "var:preset|color|charcoal"
        },
        "css": "&:after {content: '➝'; display: inline-block; font-size: 24px; line-height: 16px; vertical-align: -4px; margin: 0 -10px 0 10px; }",
        "spacing": {
          "padding": {
            "top": "17px",
            "right": "32px",
            "bottom": "15px",
            "left": "32px"
          }
        },
        "typography": {
          "fontSize": "16px",
          "fontWeight": "500",
          "textDecoration": "none !important"
        },
        "variations": {
          "outline": {
            "border": {
              "width": "1px"
            },
            "spacing": {
              "padding": {
                "top": "16px",
                "right": "31px",
                "bottom": "14px",
                "left": "31px"
              }
            }
          }
        }
      },
      "core/buttons": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|50"
          }
        }
      },
      "core/columns": {
        "spacing": {
          "blockGap": "var:preset|spacing|70",
          "margin": {
            "top": "var:preset|spacing|60",
            "bottom": "var:preset|spacing|20"
          }
        }
      },
      "core/cover": {
        "dimensions": {
          "minHeight": "0"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|70",
            "bottom": "var:preset|spacing|70"
          },
          "padding": {
            "top": "var:preset|spacing|70",
            "bottom": "var:preset|spacing|70"
          }
        }
      },
      "core/list": {
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|50"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|medium"
        }
      },
      "core/more": {
        "css": "& input{ text-transform: none; }"
      },
      "core/paragraph": {
        "css": " &:is(p.is-style-caption) { font-size: var(--wp--preset--font-size--x-small); line-height: 1.25; color: var(--wp--preset--color--gray); } &:is(p.is-style-caption):last-of-type { border-top: 1px solid var(--wp--preset--color--mint-dark); margin-top: var(--wp--preset--font-size--xx-large); padding-top: var(--wp--preset--font-size--medium-large); } &:is(p.is-style-caption.block-editor-block-list__block) { border-top-width: 2px; }",
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|30",
            "bottom": "var:preset|spacing|20"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|medium"
        }
      },
      "core/post-title": {
        "css": "&:is(h1.editor-post-title) { font-size: var(--wp--preset--font-size--xx-large); font-weight: 600; }"
      },
      "core/quote": {
        "css": "& cite > strong { font-weight: 700}",
        "elements": {
          "cite": {
            "typography": {
              "fontSize": "var:preset|font-size|small",
              "fontWeight": "400"
            }
          }
        }
      },
      "core/separator": {
        "border": {
          "width": "0"
        },
        "color": {
          "background": "var:preset|color|charcoal"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|50"
          },
          "padding": {
            "top": "2px"
          }
        }
      }
    }
  }
}