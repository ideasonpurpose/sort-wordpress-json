{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "layout": {
      "contentSize": "844px",
      "wideSize": "1024px"
    },
    "typography": {
      "fluid": true,
      "fontSizes": [
        {
          "size": "14px",
          "slug":   "x-small",
          "name":      "Extra Small",
          "fluid": {
            "max": "14px",
            "min": "12px"
          }
        },
        { "size": "16px", "slug": "small", "name": "Small", "fluid": { "min": "14px", "max": "16px" } },
        {
          "size": "20px",
          "slug": "medium",
          "name": "Medium",
          "fluid": { "min": "16px", "max": "20px" }
        }
      ]
    }
  }
}
