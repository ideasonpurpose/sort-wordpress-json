{
  "name": "@ideasonpurpose/sort-wordpress-json",
  "version": "0.0.5",
  "description": "Sorts WordPress JSON files. Because things should be where things should be.",
  "keywords": [
    "wordpress",
    "json",
    "sort",
    "theme.json",
    "block.json"
  ],
  "license": "MIT",
  "author": "Ideas On Purpose (https://www.ideasonpurpose.com/)",
  "contributors": [
    "Joe Maller <joe@ideasonpurpose.com>"
  ],
  "type": "module",
  "main": "index.js",
  "bin": {
    "sort-wp-json": "./cli.js"
  },
  "scripts": {
    "prepare": "npm run schema:refresh",
    "schema:refresh": "node bin/refresh-schemas.js",
    "test": "vitest",
    "version": "version-everything && git add -u"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.5",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "detect-indent": "^7.0.2",
    "env-paths": "^4.0.0",
    "fast-glob": "^3.3.3",
    "flat-cache": "^6.1.22",
    "get-value": "^4.0.1",
    "jsonc-parser": "^3.3.1",
    "jsonschema": "^1.5.0",
    "lodash.clonedeep": "^4.5.0",
    "lodash.merge": "^4.6.2",
    "ora": "^9.3.0",
    "prettier": "^3.8.2",
    "pretty-ms": "^9.3.0",
    "set-value": "^4.1.0",
    "sort-object-keys": "^2.1.0",
    "unset-value": "^2.0.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/detect-indent": "^6.0.3",
    "@types/get-value": "^3.0.5",
    "@types/lodash.isequal": "^4.5.8",
    "@types/node": "^25.6.0",
    "@types/set-value": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^6.0.2",
    "version-everything": "^0.12.2",
    "vitest": "^4.1.4"
  },
  "version-everything": {
    "files": [
      "README.md"
    ]
  }
}
